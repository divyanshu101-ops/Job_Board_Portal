<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Board Portal</title>

    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>

    <div class="container">

        <header class="dashboard-header">

            <h1 class="page-title">
                Job Board Dashboard
            </h1>

            <p class="page-subtitle">
                Explore jobs, companies, and hiring trends.
            </p>

            <a href="/job" class="view-jobs-btn">
                Browse Jobs
            </a>

        </header>

        <section class="stats-card">

            <h2 class="section-title">
                Platform Statistics
            </h2>

            <ul class="stats-list">

                <li class="stat-item">
                    <strong>Total Active Jobs:</strong>
                    <span><%= totalActive.count %></span>
                </li>

                <li class="stat-item">
                    <strong>Total Companies:</strong>
                    <span><%= totalCompanies.count %></span>
                </li>

                <li class="stat-item">
                    <strong>Active Cities:</strong>
                    <span><%= totalCities.count %></span>
                </li>

            </ul>

        </section>

        <section class="latest-jobs-card">

            <h2 class="section-title">
                Top 5 Latest Jobs
            </h2>

            <% if(latestJobs.length > 0) { %>

                <ul class="latest-jobs-list">

                    <% latestJobs.forEach(job => { %>

                        <li class="latest-job-item">

                            <strong class="job-role">
                                <%= job.role %>
                            </strong>

                            <span class="job-company">
                                at <%= job.company %>
                            </span>

                        </li>

                    <% }) %>

                </ul>

            <% } else { %>

                <p class="empty-message">
                    No jobs available.
                </p>

            <% } %>

            <div class="dashboard-actions">

                <a href="/job" class="view-jobs-btn">
                    View All Jobs
                </a>

            </div>

        </section>

    </div>

</body>
</html>